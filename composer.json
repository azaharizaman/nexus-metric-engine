{
    "name": "azaharizaman/nexus-metric-engine",
    "description": "Deterministic Layer 1 metric calculation engine for Nexus packages.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "metrics",
        "calculation",
        "formula",
        "time-series",
        "nexus",
        "batch",
        "catalog",
        "audit",
        "fingerprint",
        "banded-scores"
    ],
    "homepage": "https://github.com/azaharizaman/nexus-metric-engine",
    "authors": [
        {
            "name": "Nexus Architecture Team",
            "email": "architecture@nexus.dev"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\MetricEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\MetricEngine\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/azaharizaman/nexus-metric-engine/issues",
        "source": "https://github.com/azaharizaman/nexus-metric-engine"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
